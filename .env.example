# Copy to .env and fill in. .env is gitignored — never commit real values.
# In GitHub Actions these live as encrypted repository secrets instead
# (Settings -> Secrets and variables -> Actions). See README section 4.

# --- Required: relevance scoring ---------------------------------------------
# https://console.anthropic.com/  (only metered cost — a few cents/day)
ANTHROPIC_API_KEY=

# --- Email delivery (Gmail SMTP, mirrors the eb-rank setup) ------------------
# A Gmail *App Password* (16 chars), NOT your account password. Requires 2FA:
# https://myaccount.google.com/apppasswords
# In CI this is the secret GMAIL_APP_PASSWORD consumed by the send-mail action.
GMAIL_APP_PASSWORD=

# Sender + recipient. Defaults bake in luis.goicouria@gmail.com if unset.
GMAIL_USER=luis.goicouria@gmail.com
DIGEST_TO=luis.goicouria@gmail.com

# --- Optional: raises Semantic Scholar rate limits (citation path) -----------
# Works fine without it; just slower / more 429s.
# https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=

# --- Optional: override the Gmail SMTP defaults for a different provider -----
# If set, these take precedence over the GMAIL_* values above for local sends.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
